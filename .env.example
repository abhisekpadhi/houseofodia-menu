GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=
GITHUB_ACCESS_TOKEN=
GIST_ID=
ABLY_API_KEY=
# Optional Ably channel override (default: order_ops). Set NEXT_PUBLIC_ABLY_CHANNEL for browser sync.
ABLY_CHANNEL=
NEXT_PUBLIC_ABLY_CHANNEL=
# Lambda Function URL base (no trailing slash), called directly from browser on /rate
NEXT_PUBLIC_TANGIFY_API_BASE_URL=
# Server-only service JWT used by /api/bills. Never expose with NEXT_PUBLIC_.
TANGIFY_BILLING_TOKEN=
# Optional override. Defaults to dev under `next dev`, production otherwise.
TANGIFY_BILLING_ENV=
