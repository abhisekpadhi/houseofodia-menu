GOOGLE_SHEETS_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=
GITHUB_ACCESS_TOKEN=
GIST_ID=
ABLY_API_KEY=
# Optional Ably channel override (default: order_ops). Set NEXT_PUBLIC_ABLY_CHANNEL for browser sync.
ABLY_CHANNEL=
NEXT_PUBLIC_ABLY_CHANNEL=
# Lambda Function URL base (no trailing slash), called directly from browser on /rate
NEXT_PUBLIC_TANGIFY_API_BASE_URL=
# Server-side proxy base for tangify (used by /api/tangify/*). Same URL as above.
TANGIFY_API_BASE_URL=
# Staff JWT for billing/kitchen API proxy (Bearer token from POST /api/v1/auth/login)
TANGIFY_STAFF_JWT=
# Set to true to use tangify Lambda for live orders instead of localforage + Ably sync
NEXT_PUBLIC_TANGIFY_ORDERS_BACKEND=false
NEXT_PUBLIC_TANGIFY_VENUE_ID=default
